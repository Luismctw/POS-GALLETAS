# Copia este archivo como backend/.env y llena los valores
# En Hostinger estas variables se configuran en hPanel → Variables de entorno

# Puerto del servidor (Hostinger lo asigna automáticamente)
PORT=3001

# Base de datos MySQL (obtener desde hPanel → Bases de datos)
DB_HOST=localhost
DB_USER=tu_usuario_mysql
DB_PASSWORD=tu_password_mysql
DB_NAME=tu_base_de_datos

# Contraseña del panel de administración
ADMIN_PASSWORD=CambiaEstaContraseña2024!
